# Порт сервера
PORT=3000

# Секрет сессии (ОБЯЗАТЕЛЬНО замените на случайную строку в продакшене)
SESSION_SECRET=change-me-to-a-long-random-string

# Учётная запись администратора (создаётся при первом запуске)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Базовый URL сайта (используется в QR-кодах и vCard)
BASE_URL=http://localhost:3000

# Turso (LibSQL) — база данных (обязательно для продакшена)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
